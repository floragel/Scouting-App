{
  "version": 2,
  "builds": [
    {
      "src": "backend/app.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/app.py"
    },
    {
      "source": "/login",
      "destination": "frontend/pages/auth/code.html"
    },
    {
      "source": "/dashboard",
      "destination": "frontend/pages/dashboard/code.html"
    },
    {
      "source": "/admin-hub",
      "destination": "frontend/pages/admin/code.html"
    },
    {
      "source": "/teams-dir",
      "destination": "frontend/pages/teams/code.html"
    },
    {
      "source": "/events",
      "destination": "frontend/pages/events/code.html"
    },
    {
      "source": "/pit-scout",
      "destination": "frontend/pages/pit_scout/code.html"
    },
    {
      "source": "/match-scout",
      "destination": "frontend/pages/match_scout/code.html"
    },
    {
      "source": "/analytics",
      "destination": "frontend/pages/analytics/code.html"
    },
    {
      "source": "/onboarding",
      "destination": "frontend/pages/onboarding/code.html"
    },
    {
      "source": "/profile",
      "destination": "frontend/pages/profile/code.html"
    },
    {
      "source": "/profile-edit",
      "destination": "frontend/pages/profile_edit/code.html"
    },
    {
      "source": "/shared_assets/(.*)",
      "destination": "frontend/shared/$1"
    },
    {
      "source": "/",
      "destination": "frontend/pages/auth/code.html"
    }
  ]
}
